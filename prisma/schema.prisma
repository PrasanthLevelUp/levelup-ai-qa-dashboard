generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Company {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("companies")
}

model TestExecution {
  id               Int       @id @default(autoincrement())
  testName         String    @map("test_name")
  status           String
  errorMessage     String?   @map("error_message")
  healingAttempted Boolean?  @default(false) @map("healing_attempted")
  healingSucceeded Boolean?  @default(false) @map("healing_succeeded")
  durationMs       Int?      @default(0) @map("duration_ms")
  companyId        Int?      @map("company_id")
  createdAt        DateTime? @default(now()) @map("created_at")
  healingActions   HealingAction[]

  @@index([status])
  @@index([companyId], map: "idx_te_company")
  @@map("test_executions")
}

model HealingAction {
  id                 Int       @id @default(autoincrement())
  testExecutionId    Int       @map("test_execution_id")
  testName           String    @map("test_name")
  failedLocator      String    @map("failed_locator")
  healedLocator      String?   @map("healed_locator")
  healingStrategy    String    @map("healing_strategy")
  aiTokensUsed       Int?      @default(0) @map("ai_tokens_used")
  success            Boolean?  @default(false)
  confidence         Float?    @default(0)
  errorContext       String?   @map("error_context")
  validationStatus   String?   @map("validation_status")
  validationReason   String?   @map("validation_reason")
  patchPath          String?   @map("patch_path")
  companyId          Int?      @map("company_id")
  createdAt          DateTime? @default(now()) @map("created_at")
  execution          TestExecution @relation(fields: [testExecutionId], references: [id])

  @@index([testExecutionId])
  @@index([companyId], map: "idx_ha_company")
  @@map("healing_actions")
}

model LearnedPattern {
  id               Int       @id @default(autoincrement())
  testName         String    @map("test_name")
  errorPattern     String    @map("error_pattern")
  failedLocator    String    @map("failed_locator")
  healedLocator    String    @map("healed_locator")
  solutionStrategy String    @map("solution_strategy")
  confidence       Float?    @default(0)
  successCount     Int?      @default(1) @map("success_count")
  failureCount     Int?      @default(0) @map("failure_count")
  usageCount       Int?      @default(0) @map("usage_count")
  avgTokensSaved   Int?      @default(0) @map("avg_tokens_saved")
  companyId        Int?      @map("company_id")
  lastUsed         DateTime? @default(now()) @map("last_used")
  createdAt        DateTime? @default(now()) @map("created_at")

  @@unique([testName, errorPattern, failedLocator])
  @@map("learned_patterns")
}

model TokenUsage {
  id         Int       @id @default(autoincrement())
  date       String
  engine     String
  tokensUsed Int       @map("tokens_used")
  costUsd    Float     @default(0) @map("cost_usd")
  companyId  Int?      @map("company_id")
  createdAt  DateTime? @default(now()) @map("created_at")

  @@index([date])
  @@map("token_usage")
}

model HealingJob {
  id             String    @id
  repositoryId   String    @map("repository_id")
  repositoryUrl  String?   @map("repository_url")
  branch         String?
  commitSha      String?   @map("commit_sha")
  companyId      Int?      @map("company_id")
  status         String    @default("queued")
  progress       String?
  createdAt      DateTime? @map("created_at") @db.Timestamptz(6)
  startedAt      DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  result         String?
  error          String?

  @@index([status], map: "idx_jobs_status")
  @@map("healing_jobs")
}

model ProjectContext {
  id                Int       @id @default(autoincrement())
  name              String
  appUrl            String    @map("app_url")
  framework         String?
  authMethod        String?   @map("auth_method")
  selectorStrategy  String?   @map("selector_strategy")
  appDescription    String?   @map("app_description")
  navigationFlow    String?   @map("navigation_flow")
  customRules       String?   @map("custom_rules")
  credentials       String?
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")
  scripts           GeneratedScript[]

  @@map("project_contexts")
}

model GeneratedScript {
  id                    Int       @id @default(autoincrement())
  projectContextId      Int?      @map("project_context_id")
  url                   String
  pageType              String?   @map("page_type")
  instructions          String?
  scriptContent         String?   @map("script_content")
  testPlan              Json?     @map("test_plan")
  validationStatus      String?   @default("pending") @map("validation_status")
  reliabilityScore      Float?    @default(0) @map("reliability_score")
  reviewScore           Float?    @map("review_score")
  reviewIssues          Json?     @map("review_issues")
  tokensUsed            Int?      @default(0) @map("tokens_used")
  model                 String?
  generationTimeMs      Int?      @map("generation_time_ms")
  filesGenerated        Json?     @map("files_generated")
  negativeTestsIncluded Boolean?  @default(true) @map("negative_tests_included")
  companyId             Int?      @map("company_id")
  createdAt             DateTime? @default(now()) @map("created_at")
  projectContext        ProjectContext? @relation(fields: [projectContextId], references: [id])

  @@index([url], map: "idx_gs_url")
  @@index([createdAt(sort: Desc)], map: "idx_gs_created")
  @@map("generated_scripts")
}

// ToolConnection model removed — tool configs stored in Railway DB only.
// Dashboard proxies /api/tools to backend API.