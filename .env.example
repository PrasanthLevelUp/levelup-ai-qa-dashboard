# Database Connection (shared PostgreSQL - read-only stats queries)
DATABASE_URL="postgresql://user:password@localhost:5432/levelup_qa_dashboard"

# Backend API (Railway - write operations: healing, repos, jobs)
BACKEND_API_URL="http://levelup-ai-qa-agent-production.up.railway.app"
BACKEND_API_KEY="your-api-key-here"

# NextAuth (auto-configured in production)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-here
